# Benchmark dataset (lives in pii-anon-eval-data repo)
packages/pii_anon_datasets/src/pii_anon_datasets/benchmarks/data/*.jsonl

# Benchmark artifacts — generated by scripts/run_competitor_benchmark.py
# These should only live in artifacts/benchmarks/ (auto-cleanup moves old runs
# to artifacts/benchmarks/_archive/).  The ``/`` prefix anchors these at
# the repo root so the vendored baseline at
# ``src/pii_anon/eval_framework/baselines/benchmark-results.json`` is not
# accidentally excluded from the wheel.
artifacts/benchmarks/_archive/
/benchmark-results.json
/benchmark-raw.csv
/benchmark-diagnostics.json
/floor-gate-report.md

# Local workspace archive — used for ad-hoc scratch / stashed runs.
# Not part of the shipped library.
_archive/
